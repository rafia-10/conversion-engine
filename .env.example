# ============================================================
# Tenacious Conversion Engine — Environment Variables
# Copy to .env and fill in values before running.
# NEVER commit .env to version control.
# ============================================================

# ── LLM (OpenRouter — DeepSeek V3 is default) ──────────────
OPENROUTER_API_KEY=your_openrouter_api_key_here

# ── Kill Switch (CRITICAL) ──────────────────────────────────
# Default: sandbox — all outbound goes to outputs/sandbox_sink.jsonl
# Set to "live" ONLY with program-staff + Tenacious approval
KILL_SWITCH=sandbox
SANDBOX_SINK_PATH=outputs/sandbox_sink.jsonl

# ── Email (Resend) ──────────────────────────────────────────
RESEND_API_KEY=re_your_resend_api_key
RESEND_FROM_EMAIL=Tenacious Engine <onboarding@resend.dev>
RESEND_REPLY_TO=you@yourcompany.com

# ── SMS (Africa's Talking) ──────────────────────────────────
AFRICASTALK_API_KEY=your_at_api_key
AFRICASTALK_USERNAME=sandbox
AFRICASTALK_SENDER=Tenacious

# ── CRM (HubSpot) ──────────────────────────────────────────
HUBSPOT_ACCESS_KEY=pat-eu1-your_hubspot_access_token
HUBSPOT_BASE_URL=https://api.hubapi.com

# ── Calendar (Cal.com self-hosted) ─────────────────────────
CALCOM_URL=http://localhost:3000
CALCOM_API_KEY=your_calcom_api_key
CALCOM_EVENT_TYPE_ID=1

# ── Observability (Langfuse) ────────────────────────────────
LANGFUSE_SECRET_KEY=sk-lf-your_langfuse_secret
LANGFUSE_PUBLIC_KEY=pk-lf-your_langfuse_public
LANGFUSE_BASE_URL=https://cloud.langfuse.com

# ── Webhook server ─────────────────────────────────────────
WEBHOOK_BASE_URL=https://your-ngrok-url.ngrok.io
WEBHOOK_PORT=8000

# ── Data paths ─────────────────────────────────────────────
CRUNCHBASE_SAMPLE_PATH=data/crunchbase_sample.json
LAYOFFS_DATA_PATH=data/layoffs.fyi.csv
JOB_POSTS_DATA_PATH=data/job_posts.json

# ── τ²-Bench (eval) ────────────────────────────────────────
TAU2_MODEL=openai/deepseek/deepseek-chat-v3-0324
# OPENAI_API_BASE is set automatically by eval/harness.py from OPENROUTER_API_KEY
